# Synthetic example environment — no real portfolio data needed.
#
# Source this file before starting JupyterLab to run notebooks and scripts
# against the committed synthetic fixtures in data/examples/:
#
#   source .env.example
#   docker compose up
#   → http://localhost:8888/lab
#
# With these variables set:
# - Notebooks 06 and 07 run in PDF mode reading the pre-parsed synthetic parquets.
# - Notebook 08 shows composition breakdowns for the synthetic holdings.
# - Scripts (parse_db_pdf.py, portfolio_snapshot.py, stop_loss_real_portfolio.py,
#   portfolio_composition.py) pick up these paths as defaults when no CLI flag is given.
#
# For real portfolio data, copy .env.private.example to .env.private instead.
# .env.private is gitignored and must never be committed.

# Pre-parsed synthetic holdings snapshot (data/examples/ is committed and public)
export HOLDINGS_PATH=data/examples/db_holdings_synthetic.parquet

# Pre-parsed synthetic transaction history
export TRANSACTIONS_PATH=data/examples/db_transactions_synthetic.parquet

# Synthetic ISIN -> Yahoo Finance ticker map
export TICKER_MAP_PATH=data/examples/ticker_map_synthetic.json

# NOTE: DB_PDF_PATH is intentionally not set here.
# The synthetic dataset is already parsed into parquet files above.
# Setting DB_PDF_PATH to a non-existent synthetic PDF would cause errors.
# Notebooks 06 and 07 read HOLDINGS_PATH / TRANSACTIONS_PATH directly.
