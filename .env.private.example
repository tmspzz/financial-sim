# Portfolio pipeline — private data paths
#
# Copy this file to .env.private, fill in your real paths, and source it
# before starting JupyterLab:
#
#   cp .env.private.example .env.private
#   # edit .env.private with your actual filenames
#   source .env.private
#   docker compose up
#
# .env.private is gitignored. This example file is committed as a template.
#
# ── Step 1: set the source PDF ────────────────────────────────────────────────
#
# Your Deutsche Bank Vermögensanlage-Report PDF. Path is relative to the
# project root (or absolute). File must live under data/private/ (gitignored).
#
export DB_PDF_PATH=data/private/report.pdf

# ── Step 2: run parse_db_pdf.py once ─────────────────────────────────────────
#
#   docker run --rm \
#     -v "$PWD":/home/jovyan/work \
#     -w /home/jovyan/work \
#     -e PYTHONPATH=/home/jovyan/work/src \
#     financial-sim:latest \
#     python scripts/parse_db_pdf.py \
#       --input "$DB_PDF_PATH" \
#       --output-dir data/private/
#
# This writes two files. Set their paths below (replace <stem> with the
# PDF filename without extension, e.g. "report" → "report_holdings"):
#
export HOLDINGS_PATH=data/private/report_holdings.parquet
export TRANSACTIONS_PATH=data/private/report_transactions.parquet

# ── Lookup files (build these once, update as holdings change) ────────────────
#
# TICKER_MAP_PATH: JSON mapping ISIN → Yahoo Finance ticker symbol.
# Example entry: { "IE00B4L5Y983": "IWDA.AS", "NL0010273215": "ASML.AS" }
# Start with just the ISINs in your holdings; add more as needed.
#
export TICKER_MAP_PATH=data/private/ticker_map.json

# ETF_URLS_PATH: JSON mapping ETF ISIN → constituent CSV download URL.
# Find the "Download holdings" CSV link on the fund provider website (iShares,
# Amundi, etc.) and paste it here. One entry per ETF you hold.
# Example: { "IE00B4L5Y983": "https://www.ishares.com/.../holdings.csv?..." }
# Leave file empty ({}) to skip full look-through (Yahoo top-10 fallback used).
#
export ETF_URLS_PATH=data/private/etf_download_urls.json

# ETF_OVERRIDES_PATH: JSON mapping ETF ISIN → "accumulating" or "distributing".
# Optional. Used when the fund name heuristic (Acc/Dist suffix) is ambiguous.
# Example: { "IE00B4L5Y983": "accumulating" }
#
export ETF_OVERRIDES_PATH=data/private/etf_structure_overrides.json

# SNAPSHOT_DATE: ISO date (YYYY-MM-DD) for the holdings snapshot.
# Used by notebook 08 to flag constituent data older than 90 days.
# Defaults to today if not set. Set it to the PDF report date for consistency.
#
# export SNAPSHOT_DATE=2026-01-31
