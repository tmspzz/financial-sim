# ── Scratch workspace ────────────────────────────────────────────────────────
# Throwaway exploration files written during agent solution sketching.
# Never committed. See .agents/execution-and-validation.md.
scratch/*
!scratch/.gitkeep

# ── Executed notebook outputs ─────────────────────────────────────────────────
# Generated by running notebooks inside Docker. Fully reproducible.
# Regenerate with: docker run ... jupyter nbconvert --execute
executed/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
# In-progress checkpoint files created by JupyterLab autosave.
.ipynb_checkpoints/

# ── Docker ────────────────────────────────────────────────────────────────────
# Nothing from the project itself ends up here, but ignore any local overrides.
docker-compose.override.yml

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
